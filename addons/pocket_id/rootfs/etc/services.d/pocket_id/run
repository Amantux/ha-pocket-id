#!/usr/bin/with-contenv bashio
# shellcheck shell=bash
set -e

bashio::log.info "Starting Pocket ID..."

APP_URL="$(bashio::config 'app_url')"
ENCRYPTION_KEY="$(bashio::config 'encryption_key')"
API_KEY="$(bashio::config 'api_key')"

if bashio::var.is_empty "${ENCRYPTION_KEY}"; then
    bashio::log.warning "No encryption_key set — generating a random one and persisting it."
    if [ ! -f /data/encryption_key ]; then
        # Generate and store a stable random key so restarts don't invalidate sessions
        head -c 32 /dev/urandom | base64 > /data/encryption_key
    fi
    ENCRYPTION_KEY=$(cat /data/encryption_key)
fi

export APP_URL="${APP_URL}"
export ENCRYPTION_KEY="${ENCRYPTION_KEY}"
export TRUST_PROXY="true"
export DATA_DIR="/data"
export PORT="1411"

if ! bashio::var.is_empty "${API_KEY}"; then
    export STATIC_API_KEY="${API_KEY}"
    bashio::log.info "STATIC_API_KEY is set (${#API_KEY} chars)"
else
    # Auto-generate a stable api_key so headless API access works out of the box
    if [ ! -f /data/api_key ]; then
        bashio::log.warning "No api_key configured — generating a random one. Check /data/api_key to retrieve it."
        printf 'pocket-id-%s' "$(head -c 24 /dev/urandom | base64 | tr -d '+/=' | head -c 32)" > /data/api_key
    fi
    export STATIC_API_KEY="$(cat /data/api_key)"
    bashio::log.info "STATIC_API_KEY auto-generated (${#STATIC_API_KEY} chars) — override via 'api_key' option"
fi

bashio::log.info "APP_URL: ${APP_URL}"

exec /usr/bin/pocket-id
